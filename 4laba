

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from sklearn.model_selection import train_test_split, cross_val_score, StratifiedKFold
from sklearn.preprocessing import StandardScaler, MinMaxScaler
from sklearn.naive_bayes import ComplementNB
from sklearn.linear_model import Perceptron
from sklearn.metrics import accuracy_score, classification_report, confusion_matrix, ConfusionMatrixDisplay
from sklearn.cluster import KMeans
from sklearn.decomposition import PCA
from sklearn.metrics import adjusted_rand_score


# 1. ЗАГРУЗКА ДАННЫХ

print("Классификаторы: ComplementNB и Perceptron")


# Загрузка данных =
train = pd.read_csv('disease_train.csv')
test_public = pd.read_csv('disease_public_test.csv')
sample_submission = pd.read_csv('disease_sample_submission.csv')

print("\n1. ЗАГРУЗКА ДАННЫХ")
print(f"Размер обучающей выборки: {train.shape}")
print(f"Размер тестовой выборки (public): {test_public.shape}")
print(f"Размер sample_submission: {sample_submission.shape}")

# Определение целевого столбца и признаков
target = 'Y'
features = ['X1', 'X2', 'X3', 'X4', 'X5', 'X6', 'X7']

# Выделение данных
X_train = train[features].copy()
y_train = train[target].copy()
X_test = test_public[features].copy()
y_test = sample_submission[target].values

print(f"Распределение классов в обучающей выборке:")
print(y_train.value_counts())

# 2. ОБУЧЕНИЕ НА СЫРЫХ ДАННЫХ

print("\n2. ОБУЧЕНИЕ НА СЫРЫХ ДАННЫХ")

# ComplementNB на сырых данных
cnb_raw = ComplementNB()
cnb_raw.fit(X_train, y_train)
y_pred_raw_cnb = cnb_raw.predict(X_test)
acc_raw_cnb = accuracy_score(y_test, y_pred_raw_cnb)

# Perceptron на сырых данных
perc_raw = Perceptron(random_state=42, max_iter=1000, tol=1e-3)
perc_raw.fit(X_train, y_train)
y_pred_raw_perc = perc_raw.predict(X_test)
acc_raw_perc = accuracy_score(y_test, y_pred_raw_perc)

print(f"ComplementNB (сырые): {acc_raw_cnb:.4f}")
print(f"Perceptron (сырые):    {acc_raw_perc:.4f}")

# 3. ПРЕДОБРАБОТКА ДАННЫХ

print("\n3. ПРЕДОБРАБОТКА ДАННЫХ")

# Для ComplementNB: MinMaxScaler + приведение к целым (неотрицательные)
scaler_minmax = MinMaxScaler()
X_train_minmax = scaler_minmax.fit_transform(X_train)
X_test_minmax = scaler_minmax.transform(X_test)
X_train_cnb = (X_train_minmax * 100).round().astype(int)
X_test_cnb = (X_test_minmax * 100).round().astype(int)
print("ComplementNB: MinMaxScaler + умножение на 100 + округление до целых")

# Для Perceptron: StandardScaler
scaler_std = StandardScaler()
X_train_perc = scaler_std.fit_transform(X_train)
X_test_perc = scaler_std.transform(X_test)
print("Perceptron: StandardScaler (стандартизация)")

# 4. ОБУЧЕНИЕ НА ПРЕДОБРАБОТАННЫХ ДАННЫХ

print("\n4. ОБУЧЕНИЕ НА ПРЕДОБРАБОТАННЫХ ДАННЫХ")

cnb = ComplementNB()
cnb.fit(X_train_cnb, y_train)
y_pred_cnb = cnb.predict(X_test_cnb)
acc_cnb = accuracy_score(y_test, y_pred_cnb)

perc = Perceptron(random_state=42, max_iter=1000, tol=1e-3)
perc.fit(X_train_perc, y_train)
y_pred_perc = perc.predict(X_test_perc)
acc_perc = accuracy_score(y_test, y_pred_perc)

print(f"ComplementNB (предобр.): {acc_cnb:.4f}")
print(f"Perceptron (предобр.):    {acc_perc:.4f}")

# 5. КРОСС-ВАЛИДАЦИЯ

print("\n5. КРОСС-ВАЛИДАЦИЯ (StratifiedKFold, n_splits=5)")

skf = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)

cv_cnb = cross_val_score(cnb, X_train_cnb, y_train, cv=skf)
cv_perc = cross_val_score(perc, X_train_perc, y_train, cv=skf)

print(f"ComplementNB: {cv_cnb.mean():.4f} (+/- {cv_cnb.std():.4f})")
print(f"Perceptron:    {cv_perc.mean():.4f} (+/- {cv_perc.std():.4f})")

# 6. ОТЧЁТЫ КЛАССИФИКАЦИИ

print("\n6. ОТЧЁТЫ КЛАССИФИКАЦИИ")

print("\nClassification Report для ComplementNB:")
print(classification_report(y_test, y_pred_cnb, target_names=['Класс 0', 'Класс 1']))

print("\nClassification Report для Perceptron:")
print(classification_report(y_test, y_pred_perc, target_names=['Класс 0', 'Класс 1']))

# 7. МАТРИЦЫ ОШИБОК

print("\n7. ПОСТРОЕНИЕ МАТРИЦ ОШИБОК")

fig, axes = plt.subplots(1, 2, figsize=(12, 5))

ConfusionMatrixDisplay.from_predictions(y_test, y_pred_cnb, ax=axes[0], colorbar=False)
axes[0].set_title(f'ComplementNB (accuracy = {acc_cnb:.3f})')

ConfusionMatrixDisplay.from_predictions(y_test, y_pred_perc, ax=axes[1], colorbar=False)
axes[1].set_title(f'Perceptron (accuracy = {acc_perc:.3f})')

plt.tight_layout()
plt.savefig('confusion_matrices.png', dpi=150)
plt.show()

# 8. СРАВНЕНИЕ ТОЧНОСТИ (ГРАФИК)

print("\n8. СРАВНЕНИЕ ТОЧНОСТИ КЛАССИФИКАТОРОВ")

methods = ['ComplementNB\n(сырые)', 'Perceptron\n(сырые)',
           'ComplementNB\n(предобр.)', 'Perceptron\n(предобр.)']
accuracies = [acc_raw_cnb, acc_raw_perc, acc_cnb, acc_perc]
colors = ['#FF6B6B', '#4ECDC4', '#FF6B6B', '#4ECDC4']

plt.figure(figsize=(8, 5))
bars = plt.bar(methods, accuracies, color=colors, edgecolor='black')
plt.ylabel('Точность (accuracy)', fontsize=12)
plt.title('Сравнение точности классификаторов ComplementNB и Perceptron', fontsize=14)
plt.ylim(0, 1)
plt.grid(axis='y', linestyle='--', alpha=0.7)

for bar, acc in zip(bars, accuracies):
    plt.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.01,
             f'{acc:.3f}', ha='center', va='bottom', fontsize=11, fontweight='bold')

plt.tight_layout()
plt.savefig('accuracy_comparison.png', dpi=150)
plt.show()

# 9. КЛАСТЕРИЗАЦИЯ (KMeans)

print("\n9. КЛАСТЕРИЗАЦИЯ KMeans (k=2)")

kmeans = KMeans(n_clusters=2, random_state=42, n_init=10)
clusters = kmeans.fit_predict(X_train_perc)

ari = adjusted_rand_score(y_train, clusters)
print(f"Adjusted Rand Index (ARI) = {ari:.4f}")
print("Интерпретация ARI: 1 - полное совпадение, 0 - случайное разбиение")

# 10. ВИЗУАЛИЗАЦИЯ КЛАСТЕРОВ (PCA)

print("\n10. ВИЗУАЛИЗАЦИЯ КЛАСТЕРОВ (PCA)")

pca = PCA(n_components=2, random_state=42)
X_pca = pca.fit_transform(X_train_perc)

plt.figure(figsize=(8, 6))
scatter = plt.scatter(X_pca[:, 0], X_pca[:, 1], c=clusters, cmap='viridis',
                      edgecolor='k', alpha=0.7, s=50)
plt.xlabel('Первая главная компонента', fontsize=12)
plt.ylabel('Вторая главная компонента', fontsize=12)
plt.title(f'Кластеры KMeans (k=2)\nARI = {ari:.4f}', fontsize=14)
plt.legend(*scatter.legend_elements(), title='Кластер', loc='best')
plt.grid(alpha=0.3)
plt.tight_layout()
plt.savefig('kmeans_clusters.png', dpi=150)
plt.show()

# 11. ИТОГОВЫЙ АНАЛИЗ


print(f"""
1. Точность на сырых данных:
   - ComplementNB: {acc_raw_cnb:.4f}
   - Perceptron:    {acc_raw_perc:.4f}

2. Точность на предобработанных данных:
   - ComplementNB: {acc_cnb:.4f}
   - Perceptron:    {acc_perc:.4f}

3. Кросс-валидация (средняя точность):
   - ComplementNB: {cv_cnb.mean():.4f} (+/- {cv_cnb.std():.4f})
   - Perceptron:    {cv_perc.mean():.4f} (+/- {cv_perc.std():.4f})

4. Кластеризация KMeans:
   - Adjusted Rand Index (ARI) = {ari:.4f}
""")

print("ВЫВОДЫ:")
print("-" * 40)
if acc_cnb > acc_perc:
    print(f"ComplementNB показал точность {acc_cnb:.4f}, что лучше Perceptron ({acc_perc:.4f})")
elif acc_perc > acc_cnb:
    print(f"Perceptron показал точность {acc_perc:.4f}, что лучше ComplementNB ({acc_cnb:.4f})")
else:
    print(f"Оба классификатора показали одинаковую точность: {acc_cnb:.4f}")

if ari > 0.7:
    print(f"Кластеризация (ARI={ari:.4f}) хорошо соответствует истинным меткам")
elif ari > 0.3:
    print(f"Кластеризация (ARI={ari:.4f}) частично соответствует истинным меткам")
else:
    print(f"Кластеризация (ARI={ari:.4f}) плохо соответствует истинным меткам, данные слабо разделимы")

