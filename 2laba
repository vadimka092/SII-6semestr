import random
import math
import time
import numpy as np
import matplotlib.pyplot as plt
from sklearn.cluster import KMeans
from sklearn.metrics import silhouette_score

# ----- 1. Генерация 15 случайных городов -----
cities = []
for i in range(15):
    cities.append({
        'id': i,
        'name': f'Город_{i+1}',
        'x': random.randint(0, 100),
        'y': random.randint(0, 100)
    })

print("Сгенерированные города:")
for c in cities:
    print(f"  {c['name']}: ({c['x']}, {c['y']})")
print()

# ----- 2. Общие вспомогательные функции -----
def distance(city1, city2):
    return math.hypot(city1['x'] - city2['x'], city1['y'] - city2['y'])

def compute_wcss(clusters, centroids_coords):
    """WCSS = сумма квадратов расстояний от точек до центроидов"""
    wcss = 0.0
    for i, cluster in enumerate(clusters):
        cx, cy = centroids_coords[i]
        for city in cluster:
            wcss += (city['x'] - cx)**2 + (city['y'] - cy)**2
    return wcss

# ----- 3. Алгоритмический метод (жадный) -----
def algorithmic_clustering(cities, k):
    """Возвращает clusters (список списков городов), centroids_coords, wcss"""
    n = len(cities)
    if k >= n:
        clusters = [[city] for city in cities]
        centroids = [(city['x'], city['y']) for city in cities]
        return clusters, centroids, 0.0

    # матрица расстояний
    dist_mat = [[0.0]*n for _ in range(n)]
    for i in range(n):
        for j in range(i+1, n):
            d = distance(cities[i], cities[j])
            dist_mat[i][j] = dist_mat[j][i] = d

    # 1) первый центр – город с минимальной суммой расстояний
    sum_dist = [sum(dist_mat[i]) for i in range(n)]
    first_idx = sum_dist.index(min(sum_dist))
    centers_idx = [first_idx]

    # 2) жадный выбор остальных центров (максимизация минимального расстояния)
    while len(centers_idx) < k:
        best_idx = -1
        max_min = -1.0
        for i in range(n):
            if i in centers_idx:
                continue
            min_d = min(dist_mat[i][j] for j in centers_idx)
            if min_d > max_min:
                max_min = min_d
                best_idx = i
        if best_idx == -1:
            break
        centers_idx.append(best_idx)

    # координаты центров
    centroids = [(cities[idx]['x'], cities[idx]['y']) for idx in centers_idx]

    # распределение городов по ближайшему центру
    clusters = [[] for _ in range(k)]
    for i, city in enumerate(cities):
        if i in centers_idx:
            pos = centers_idx.index(i)
            clusters[pos].append(city)
        else:
            best = 0
            best_dist = float('inf')
            for ci, (cx, cy) in enumerate(centroids):
                d = math.hypot(city['x'] - cx, city['y'] - cy)
                if d < best_dist:
                    best_dist = d
                    best = ci
            clusters[best].append(city)

    wcss = compute_wcss(clusters, centroids)
    return clusters, centroids, wcss

def find_optimal_k_algorithmic(cities, max_k=5):
    """Поиск оптимального K для алгоритмического метода методом локтя"""
    wcss_vals = []
    for k in range(1, max_k+1):
        _, _, wcss = algorithmic_clustering(cities, k)
        wcss_vals.append(wcss)
    # классический поиск излома (максимальное расстояние до прямой от 1 до max_k)
    if max_k < 3:
        return 1
    x1, y1 = 1, wcss_vals[0]
    x2, y2 = max_k, wcss_vals[-1]
    max_dist = -1.0
    best_k = 1
    for k in range(1, max_k+1):
        y = wcss_vals[k-1]
        num = abs((x2-x1)*(y1-y) - (x1-k)*(y2-y1))
        den = math.hypot(x2-x1, y2-y1)
        dist = num / den if den != 0 else 0
        if dist > max_dist:
            max_dist = dist
            best_k = k
    return best_k

# ----- 4. Ручной K‑средних -----
def kmeans_manual(cities, k, max_iter=20):
    """Ручная реализация K‑средних"""
    n = len(cities)
    # случайные начальные центроиды (разные города)
    init = random.sample(cities, k)
    centroids = [(c['x'], c['y']) for c in init]

    for _ in range(max_iter):
        clusters = [[] for _ in range(k)]
        for city in cities:
            dists = [math.hypot(city['x']-cx, city['y']-cy) for (cx, cy) in centroids]
            best = dists.index(min(dists))
            clusters[best].append(city)

        new_centroids = []
        for cluster in clusters:
            if cluster:
                avg_x = sum(c['x'] for c in cluster)/len(cluster)
                avg_y = sum(c['y'] for c in cluster)/len(cluster)
                new_centroids.append((avg_x, avg_y))
            else:
                new_centroids.append((0.0, 0.0))

        # проверка сходимости
        if all(abs(new_centroids[i][0]-centroids[i][0])<1e-5 and
               abs(new_centroids[i][1]-centroids[i][1])<1e-5 for i in range(k)):
            break
        centroids = new_centroids

    # финальное распределение
    final_clusters = [[] for _ in range(k)]
    for city in cities:
        dists = [math.hypot(city['x']-cx, city['y']-cy) for (cx, cy) in centroids]
        best = dists.index(min(dists))
        final_clusters[best].append(city)

    wcss = compute_wcss(final_clusters, centroids)
    return final_clusters, centroids, wcss

def find_optimal_k_kmeans_manual(cities, max_k=5, max_iter=20):
    """Поиск оптимального K для ручного K‑средних методом локтя"""
    wcss_vals = []
    for k in range(1, max_k+1):
        _, _, wcss = kmeans_manual(cities, k, max_iter)
        wcss_vals.append(wcss)
    if max_k < 3:
        return 1
    x1, y1 = 1, wcss_vals[0]
    x2, y2 = max_k, wcss_vals[-1]
    max_dist = -1.0
    best_k = 1
    for k in range(1, max_k+1):
        y = wcss_vals[k-1]
        num = abs((x2-x1)*(y1-y) - (x1-k)*(y2-y1))
        den = math.hypot(x2-x1, y2-y1)
        dist = num / den if den != 0 else 0
        if dist > max_dist:
            max_dist = dist
            best_k = k
    return best_k

# ----- 5. Библиотечный K‑средних (sklearn) -----
def kmeans_sklearn_fixed(cities, k):
    X = np.array([[c['x'], c['y']] for c in cities])
    km = KMeans(n_clusters=k, random_state=42, n_init=10)
    km.fit(X)
    labels = km.labels_
    clusters = [[] for _ in range(k)]
    for i, c in enumerate(cities):
        clusters[labels[i]].append(c)
    return clusters, km.cluster_centers_, km.inertia_

def find_optimal_k_kmeans_sklearn(cities, max_k=5):
    X = np.array([[c['x'], c['y']] for c in cities])
    wcss_vals = []
    for k in range(1, max_k+1):
        km = KMeans(n_clusters=k, random_state=42, n_init=10)
        km.fit(X)
        wcss_vals.append(km.inertia_)
    if max_k < 3:
        return 1
    x1, y1 = 1, wcss_vals[0]
    x2, y2 = max_k, wcss_vals[-1]
    max_dist = -1.0
    best_k = 1
    for k in range(1, max_k+1):
        y = wcss_vals[k-1]
        num = abs((x2-x1)*(y1-y) - (x1-k)*(y2-y1))
        den = math.hypot(x2-x1, y2-y1)
        dist = num / den if den != 0 else 0
        if dist > max_dist:
            max_dist = dist
            best_k = k
    return best_k

# ----- 6. Вычисление метрик -----
def avg_distance_to_centroid(cities, clusters, centroids_coords):
    total = 0.0
    count = 0
    for i, cluster in enumerate(clusters):
        cx, cy = centroids_coords[i]
        for city in cluster:
            total += math.hypot(city['x']-cx, city['y']-cy)
            count += 1
    return total / count if count > 0 else 0.0

# ----- 7. Основная программа -----
MAX_K = 5   # ограничение

# Алгоритмический метод
print("="*60)
